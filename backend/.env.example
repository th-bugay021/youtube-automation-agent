NODE_ENV=development
PORT=4000
FRONTEND_ORIGIN=http://localhost:3000

# Database
DATABASE_URL=postgresql://ytauto:ytauto_secret@localhost:5432/ytauto?schema=public

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=replace-with-64-char-hex
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=replace-with-64-char-hex
JWT_REFRESH_EXPIRES_IN=7d

# OAuth (Google / YouTube)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:4000/auth/google/callback

# Encryption (32 bytes hex, used to encrypt OAuth refresh tokens at rest)
TOKEN_ENCRYPTION_KEY=

# LLM (OpenAI-compatible API: works with OpenAI, Groq, Together, etc.)
# - For OpenAI: leave OPENAI_BASE_URL empty, set OPENAI_MODEL=gpt-4o-mini
# - For Groq:   OPENAI_BASE_URL=https://api.groq.com/openai/v1, OPENAI_MODEL=llama-3.3-70b-versatile
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=gpt-4o-mini

# CSRF
CSRF_SECRET=replace-with-random-string

# Cookies
COOKIE_DOMAIN=localhost
COOKIE_SECURE=false

# === AI Video Creation Studio ===
# Supabase Storage (use the same project as DATABASE_URL).
# Service role key bypasses RLS — keep it server-side only.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=studio

# Pixabay (free image API, https://pixabay.com/api/docs/)
PIXABAY_KEY=

# ElevenLabs (optional — leave empty to render silent audio)
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM
